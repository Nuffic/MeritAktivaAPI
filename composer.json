{
    "name": "madisx/merit-aktiva-api",
    "description": "PHP Api for Merit Aktiva API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Madis Kapsi",
            "email": "madis@scr.ee"
        }
    ],
    "autoload": {
        "psr-4": {
          "Infira\\MeritAktiva\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Infira\\MeritAktiva\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.4",
        "phpseclib/bcmath_compat": "^2.0",
        "symfony/polyfill-php80": "^1.0.0",
        "symfony/polyfill-php81": "^1.0.0",
        "symfony/polyfill-php82": "^1.0.0",
        "symfony/polyfill-php83": "^1.0.0"
    },
    "suggest": {
        "ext-bcmath": "Native bcmath is faster; the polyfill is used as fallback"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0"
    },
    "scripts": {
        "test": "phpunit"
    }
}